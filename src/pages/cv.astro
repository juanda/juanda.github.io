---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CV | Juan David Rodriguez Garcia</title>
    <meta
      name="description"
      content="Curriculum vitae de Juan David Rodriguez Garcia: educacion, software, sistemas, IA y proyectos digitales."
    />
  </head>
  <body class="min-h-screen bg-[#f3efe5] text-slate-900">
    <div class="mx-auto max-w-6xl px-6 py-10 md:px-8 print:max-w-none print:px-0 print:py-0">
      <header class="overflow-hidden rounded-[2rem] border border-slate-300 bg-white shadow-[0_24px_80px_rgba(15,23,42,0.08)] print:rounded-none print:border-0 print:shadow-none">
        <div class="grid gap-0 lg:grid-cols-[1.15fr_0.85fr]">
          <section class="bg-[linear-gradient(135deg,#0b1720,#102f2d_58%,#18574c)] px-8 py-10 text-white md:px-10 md:py-12">
            <div class="inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs uppercase tracking-[0.28em] text-emerald-100">
              Curriculum Vitae
            </div>
            <h1 class="mt-6 max-w-3xl text-4xl font-semibold tracking-tight md:text-6xl">
              {profile.name}
            </h1>
            <p class="mt-5 max-w-3xl text-lg leading-8 text-emerald-50/90">
              {profile.headline}
            </p>
            <p class="mt-6 max-w-3xl text-sm leading-7 text-emerald-100/75 md:text-base">
              {profile.summary}
            </p>
            <div class="mt-8 flex flex-wrap gap-3 text-sm">
              <a
                href={profile.linkedin}
                class="rounded-full border border-white/15 bg-white/10 px-4 py-2 text-white transition hover:bg-white/16"
              >
                LinkedIn
              </a>
              <a
                href={profile.github}
                class="rounded-full border border-white/15 bg-white/10 px-4 py-2 text-white transition hover:bg-white/16"
              >
                GitHub
              </a>
              <a
                href={profile.website}
                class="rounded-full border border-white/15 bg-white/10 px-4 py-2 text-white transition hover:bg-white/16"
              >
                Web
              </a>
              <a
                href="/"
                class="rounded-full border border-white/15 bg-white px-4 py-2 text-slate-900 transition hover:bg-emerald-50 print:hidden"
              >
                Volver a la home
              </a>
            </div>
          </section>

          <aside class="grid gap-px bg-slate-300 text-sm print:grid-cols-2 lg:grid-cols-1">
            <div class="bg-[#f8f6f1] px-8 py-8 md:px-10">
              <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Contacto</div>
              <div class="mt-4 space-y-3 leading-7">
                <p>{profile.location}</p>
                <p>{profile.phone}</p>
                <p><a href={`mailto:${profile.email}`} class="underline decoration-slate-300 underline-offset-4">{profile.email}</a></p>
                <p><a href={profile.website} class="underline decoration-slate-300 underline-offset-4">{profile.website}</a></p>
                <p><a href={profile.linkedin} class="underline decoration-slate-300 underline-offset-4">linkedin.com/in/juandarodriguez</a></p>
              </div>
            </div>
            <div class="bg-[#f8f6f1] px-8 py-8 md:px-10">
              <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Perfil</div>
              <ul class="mt-4 space-y-3 leading-7 text-slate-700">
                {highlights.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </aside>
        </div>
      </header>

      <main class="mt-8 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] print:mt-4">
        <section class="space-y-8">
          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Experiencia</div>
            <div class="mt-6 space-y-6">
              {experience.map((item) => (
                <article class="grid gap-3 border-b border-slate-200 pb-6 last:border-b-0 last:pb-0 md:grid-cols-[220px_1fr]">
                  <div>
                    <div class="text-sm font-semibold text-slate-900">{item.role}</div>
                    <div class="mt-1 text-sm text-slate-600">{item.org}</div>
                    <div class="mt-2 inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">
                      {item.period}
                    </div>
                  </div>
                  <p class="text-sm leading-7 text-slate-700 md:text-base">{item.detail}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Proyectos relevantes</div>
            <div class="mt-6 grid gap-5 md:grid-cols-3">
              {projects.map((project) => (
                <article class="rounded-[1.4rem] border border-slate-200 bg-[#fbfaf7] p-5">
                  <div class="text-[11px] uppercase tracking-[0.22em] text-emerald-800/70">
                    {project.label}
                  </div>
                  <h2 class="mt-3 text-xl font-semibold">{project.name}</h2>
                  <p class="mt-3 text-sm leading-7 text-slate-700">{project.text}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Formacion</div>
            <div class="mt-6 space-y-5">
              {training.map((item) => (
                <article class="grid gap-2 border-b border-slate-200 pb-5 last:border-b-0 last:pb-0 md:grid-cols-[220px_1fr]">
                  <div class="text-sm text-slate-600">{item.period}</div>
                  <div>
                    <h3 class="text-base font-semibold text-slate-900">{item.title}</h3>
                    <p class="mt-1 text-sm leading-7 text-slate-700">{item.org}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        </section>

        <section class="space-y-8">
          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Competencias</div>
            <div class="mt-6 flex flex-wrap gap-3">
              {skills.map((skill) => (
                <span class="rounded-full border border-slate-300 bg-slate-50 px-3 py-1.5 text-sm text-slate-700">
                  {skill}
                </span>
              ))}
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Desarrollo y DevOps</div>
            <div class="mt-5 text-sm leading-7 text-slate-700">
              <ul class="space-y-3">
                {engineeringProfile.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Formacion impartida</div>
            <div class="mt-5 text-sm leading-7 text-slate-700">
              <ul class="space-y-3">
                {trainingHighlights.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Certificaciones e idiomas</div>
            <div class="mt-5 space-y-5 text-sm leading-7 text-slate-700">
              <ul class="space-y-3">
                {certifications.map((item) => (
                  <li>
                    <span class="font-medium text-slate-900">{item.title}</span>
                    <span>{` - ${item.meta}`}</span>
                  </li>
                ))}
              </ul>
              <ul class="space-y-3">
                {languages.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Publicaciones</div>
            <div class="mt-5 space-y-4 text-sm leading-7 text-slate-700">
              <ul class="space-y-3">
                {publications.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-slate-300 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.05)] print:rounded-none print:border-0 print:shadow-none">
            <div class="text-xs uppercase tracking-[0.24em] text-slate-500">Enlaces</div>
            <div class="mt-5 space-y-3 text-sm leading-7 text-slate-700">
              <p><a href={profile.website} class="underline decoration-slate-300 underline-offset-4">juandarodriguez.es</a></p>
              <p><a href={profile.linkedin} class="underline decoration-slate-300 underline-offset-4">LinkedIn</a></p>
              <p><a href={profile.github} class="underline decoration-slate-300 underline-offset-4">GitHub</a></p>
              <p><a href={profile.researchgate} class="underline decoration-slate-300 underline-offset-4">ResearchGate</a></p>
              <p><a href="https://learningml.org" class="underline decoration-slate-300 underline-offset-4">LearningML</a></p>
              <p><a href="https://echidna.es" class="underline decoration-slate-300 underline-offset-4">Echidna Educacion</a></p>
              <p><a href={profile.projects} class="underline decoration-slate-300 underline-offset-4">Desarrollos</a></p>
              <p><a href={profile.courses} class="underline decoration-slate-300 underline-offset-4">Cursos</a></p>
            </div>
          </section>
        </section>
      </main>
    </div>
  </body>
</html>
